# ============================================================
# Entorno virtual
# ============================================================
.venv/
venv/
env/

# ============================================================
# Datos y modelos (ficheros grandes — no van al repo)
# ============================================================
# Toda la carpeta Articulo 1/ contiene datos raw (.tif, .npy),
# datasets procesados y pesos de modelos (.pth). Nada de esto
# va al repo. El codigo para generarlos esta en data/ y scripts/
Articulo 1/

# ============================================================
# Resultados generados (se pueden regenerar)
# ============================================================
results/**/*.png
results/**/*.db
results/**/*.joblib
results/**/run_log.txt

# Los metrics.json SI se incluyen (son ligeros y documentan resultados)
# results/**/*.json  <-- NO ignorar

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

